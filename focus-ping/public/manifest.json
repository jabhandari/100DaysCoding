{
  "manifest_version": 3,
  "name": "Focus Ping",
  "version": "1.0.0",
  "description": "Smart break reminders while you work.",
  "permissions": ["notifications", "storage", "idle"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Focus Ping"
  },
  "icons": {
    "128": "icon.png"
  }
}